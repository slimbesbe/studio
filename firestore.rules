
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    // LISTE BLANCHE MATÉRIELLE STRICTE
    function isAdmin() {
      return isSignedIn() && (
        request.auth.uid == "vwyrAnNtQkSojYSEEK2qkRB5feh2" || 
        request.auth.uid == "GPgreBe1JzZYbEHQGn3xIdcQGQs1" ||
        (request.auth.token.email != null && request.auth.token.email.lower() == "slim.besbes@yahoo.fr")
      );
    }

    // L'admin reconnu a un accès total immédiat
    match /{document=**} {
      allow read, write: if isAdmin();
    }

    // Règles spécifiques pour les utilisateurs
    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
      
      match /{allSubcollections=**} {
        allow read, write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      }
    }

    match /coachingGroups/{groupId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /questions/{questionId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    match /coachingSessions/{sessionId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /coachingAttempts/{attemptId} {
      allow read: if isSignedIn() && (isAdmin() || (resource != null && resource.data.userId == request.auth.uid));
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && (isAdmin() || (resource != null && resource.data.userId == request.auth.uid));
      allow update: if isAdmin();
    }

    match /quickQuizAttempts/{attemptId} {
      allow read: if isSignedIn() && (isAdmin() || (resource != null && resource.data.userId == request.auth.uid));
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && (isAdmin() || (resource != null && resource.data.userId == request.auth.uid));
      allow update: if isAdmin();
    }

    // Autoriser la lecture des contenus de formation pour tous les membres
    match /mindsets/{mindsetId} {
      allow read: if isSignedIn();
    }
    
    match /concepts_approaches/{approachId} {
      allow read: if isSignedIn();
    }
    
    match /concepts_domains/{domainId} {
      allow read: if isSignedIn();
    }
  }
}
