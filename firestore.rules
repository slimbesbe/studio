rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- FONCTIONS DE BASE ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    // ACCÈS PRIORITAIRE ABSOLU POUR L'ADMINISTRATEUR PRINCIPAL
    // Utilisation des UIDs et de l'Email en priorité matérielle
    function isAdmin() {
      return isSignedIn() && (
        request.auth.uid == "vwyrAnNtQkSojYSEEK2qkRB5feh2" || 
        request.auth.uid == "GPgreBe1JzZYbEHQGn3xIdcQGQs1" ||
        (request.auth.token.email != null && request.auth.token.email.lower() == "slim.besbes@yahoo.fr")
      );
    }

    // L'admin reconnu a un accès total partout
    match /{document=**} {
      allow read, write: if isAdmin();
    }

    // Règles spécifiques pour les utilisateurs (sécurité élève)
    match /users/{userId} {
      // Un élève lit son propre profil, l'admin lit tout
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      // Seul l'admin peut lister la collection complète
      allow list: if isAdmin();
      
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
      
      // Sous-collections privées (tentatives, erreurs, etc.)
      match /{allSubcollections=**} {
        allow read, write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      }
    }

    match /coachingGroups/{groupId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /questions/{questionId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    match /coachingSessions/{sessionId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /coachingAttempts/{attemptId} {
      // Un élève ne lit que ses propres scores via filtre userId, l'admin voit tout
      allow read: if isSignedIn() && (isAdmin() || (resource != null && resource.data.userId == request.auth.uid));
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }
  }
}