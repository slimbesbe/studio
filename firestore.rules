rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- FONCTIONS DE BASE ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    // ACCÈS PRIORITAIRE ABSOLU POUR L'ADMINISTRATEUR PRINCIPAL
    function isSuperAdmin() {
      return isSignedIn() && (
        request.auth.token.email.lower() == "slim.besbes@yahoo.fr" ||
        request.auth.uid == "vwyrAnNtQkSojYSEEK2qkRB5feh2" || 
        request.auth.uid == "GPgreBe1JzZYbEHQGn3xIdcQGQs1"
      );
    }

    function isAdmin() { 
      return isSuperAdmin() || (isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)));
    }

    // L'admin peut tout faire partout
    match /{document=**} {
      allow read, write: if isAdmin();
    }

    match /users/{userId} {
      // Autoriser la lecture du profil propre
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      // Autoriser la détection de synchronisation par email (limité aux admins réels)
      allow list: if isAdmin();
      
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
      
      // Sous-collections privées
      match /{allSubcollections=**} {
        allow read, write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      }
    }

    match /roles_admin/{userId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }

    match /coachingGroups/{groupId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /questions/{questionId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    match /coachingSessions/{sessionId} {
      // Lecture simplifiée pour éviter les erreurs de listes complexes
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /coachingAttempts/{attemptId} {
      // Un élève ne lit que ses propres scores
      allow read: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }
  }
}