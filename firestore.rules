
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    // LISTE BLANCHE MATÉRIELLE STRICTE
    function isAdmin() {
      return isSignedIn() && (
        request.auth.uid == "vwyrAnNtQkSojYSEEK2qkRB5feh2" || 
        request.auth.uid == "GPgreBe1JzZYbEHQGn3xIdcQGQs1" ||
        (request.auth.token.email != null && request.auth.token.email.lower() == "slim.besbes@yahoo.fr")
      );
    }

    // L'admin reconnu a un accès total immédiat
    match /{document=**} {
      allow read, write: if isAdmin();
    }

    // Règles spécifiques pour les utilisateurs
    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
      
      match /{allSubcollections=**} {
        allow read, write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      }
    }

    match /coachingGroups/{groupId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /questions/{questionId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    match /coachingSessions/{sessionId} {
      // Autoriser tout utilisateur connecté à lister les sessions (pour le menu coaching)
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /coachingAttempts/{attemptId} {
      // Un élève ne peut lister que ses propres tentatives via une requête filtrée par userId
      allow read: if isSignedIn() && (isAdmin() || (resource != null && resource.data.userId == request.auth.uid) || (request.query.limit <= 100 && request.query.filters.userId == request.auth.uid));
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }
  }
}
