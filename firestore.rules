
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- FONCTIONS DE BASE ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // --- LOGIQUE DES RÔLES ---
    function isSuperAdmin() {
      return isSignedIn() && (
        getUserData().role == "super_admin" || 
        request.auth.uid == "vwyrAnNtQkSojYSEEK2qkRB5feh2" || 
        request.auth.uid == "GPgreBe1JzZYbEHQGn3xIdcQGQs1" ||
        request.auth.token.email == "slim.besbes@yahoo.fr"
      );
    }

    function isCoach() {
      return isSignedIn() && getUserData().role == "coach";
    }

    function isPartner() {
      return isSignedIn() && getUserData().role == "partner";
    }

    function isAdmin() { 
      return isSuperAdmin() || (isSignedIn() && (getUserData().role == "admin"));
    }

    // --- RÈGLES PAR COLLECTION ---

    match /users/{userId} {
      // Un utilisateur voit son propre profil
      // Un coach voit les élèves de ses groupes
      // Un partenaire voit les utilisateurs de son périmètre
      allow get: if isSignedIn() && (
        request.auth.uid == userId || 
        isAdmin() || 
        (isCoach() && resource.data.groupId in getCoachGroupIds()) ||
        (isPartner() && resource.data.partnerId == request.auth.uid)
      );
      
      allow list: if isSignedIn() && (
        isAdmin() || 
        isCoach() || 
        isPartner()
      );

      allow create: if isAdmin() || isPartner();
      
      allow update: if isSignedIn() && (
        isAdmin() || 
        (request.auth.uid == userId && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'status', 'groupId', 'partnerId', 'validUntil'])) ||
        (isPartner() && resource.data.partnerId == request.auth.uid)
      );
      
      allow delete: if isAdmin();
    }

    match /coachingGroups/{groupId} {
      allow read: if isSignedIn() && (
        isAdmin() || 
        (isCoach() && resource.data.coachId == request.auth.uid) ||
        (isPartner() && resource.data.partnerId == request.auth.uid) ||
        (getUserData().groupId == groupId)
      );
      allow write: if isAdmin() || (isPartner() && request.resource.data.partnerId == request.auth.uid);
    }

    match /questions/{questionId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    match /coachingSessions/{sessionId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /coachingAttempts/{attemptId} {
      allow read: if isSignedIn() && (
        isAdmin() || 
        resource.data.userId == request.auth.uid ||
        (isCoach() && resource.data.groupId in getCoachGroupIds()) ||
        (isPartner() && get(/databases/$(database)/documents/users/$(resource.data.userId)).data.partnerId == request.auth.uid)
      );
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // --- HELPERS ---
    function getCoachGroupIds() {
      // Cette fonction nécessiterait une requête 'list' sur coachingGroups filtrée par coachId
      // Les règles Firestore ne supportent pas nativement les boucles sur collections, 
      // on utilise donc souvent la vérification directe dans le match du document.
      return []; 
    }
  }
}
