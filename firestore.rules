
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- FONCTIONS DE BASE ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- LOGIQUE DES RÔLES ---
    // Votre email et vos UIDs sont prioritaires pour éviter tout blocage
    function isSuperAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "slim.besbes@yahoo.fr" ||
        request.auth.uid == "vwyrAnNtQkSojYSEEK2qkRB5feh2" || 
        request.auth.uid == "GPgreBe1JzZYbEHQGn3xIdcQGQs1" ||
        (exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)))
      );
    }

    function isAdmin() { 
      return isSuperAdmin() || (isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin");
    }

    function isCoach() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "coach";
    }

    function isPartner() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "partner";
    }

    // --- RÈGLES PAR COLLECTION ---

    match /roles_admin/{userId} {
      // L'admin suprême peut toujours s'auto-initialiser
      allow read, write: if isSuperAdmin() || (isSignedIn() && request.auth.token.email == "slim.besbes@yahoo.fr");
    }

    match /users/{userId} {
      allow read: if isSignedIn() && (
        isOwner(userId) || isAdmin() || isCoach() || isPartner()
      );
      
      allow create: if (isSignedIn() && request.auth.token.email == "slim.besbes@yahoo.fr") || isAdmin() || isPartner();
      
      allow update: if isSignedIn() && (
        isOwner(userId) || isAdmin() || (isPartner() && resource.data.partnerId == request.auth.uid)
      );
      
      allow delete: if isAdmin();
    }

    match /coachingGroups/{groupId} {
      allow read: if isSignedIn() && (
        isAdmin() || 
        (isCoach() && resource.data.coachId == request.auth.uid) ||
        (isPartner() && resource.data.partnerId == request.auth.uid) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.groupId == groupId)
      );
      allow write: if isAdmin() || (isPartner() && (request.resource.data.partnerId == request.auth.uid || resource.data.partnerId == request.auth.uid));
    }

    match /questions/{questionId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    match /coachingSessions/{sessionId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /coachingAttempts/{attemptId} {
      allow read: if isSignedIn() && (
        isAdmin() || 
        resource.data.userId == request.auth.uid ||
        isCoach() ||
        isPartner()
      );
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }
  }
}
