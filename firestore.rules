
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isNotLocked() {
      // Un utilisateur verrouillé par la sécurité ne peut plus rien faire
      // On utilise getAfter() ou get() avec précaution
      return !isSignedIn() || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isLocked != true;
    }
    
    function isAdmin() {
      return isSignedIn() && (
        request.auth.uid in [
          "vwyrAnNtQkSojYSEEK2qkRB5feh2", 
          "GPgreBe1JzZYbEHQGn3xIdcQGQs1", 
          "ve5V0MUPoccuOdBNGYsz6QYY89L2", 
          "Adknzym5N6cMeJnYbCRaAdBrA0r1"
        ] || 
        (request.auth.token.email != null && 
         request.auth.token.email.lower() in [
           "slim.besbes@yahoo.fr", 
           "contact@inovexio.com", 
           "jedgrira1@gmail.com"
         ])
      );
    }

    // Sécurité globale pour les contenus : Pas d'accès si le compte est verrouillé
    match /questions/{q} { allow read, write: if isAdmin() || (isSignedIn() && isNotLocked()); }
    match /coachingSessions/{s} { allow read, write: if isAdmin() || (isSignedIn() && isNotLocked()); }
    match /coachingAttempts/{a} { allow read, write: if isAdmin() || (isSignedIn() && isNotLocked()); }
    match /mindsets/{m} { allow read, write: if isAdmin() || (isSignedIn() && isNotLocked()); }
    match /concepts_approaches/{c} { allow read, write: if isAdmin() || (isSignedIn() && isNotLocked()); }
    match /concepts_domains/{d} { allow read, write: if isAdmin() || (isSignedIn() && isNotLocked()); }

    match /userLogs/{logId} {
      allow create: if isSignedIn();
      allow read: if isAdmin();
    }

    match /mail/{mailId} {
      allow create: if isSignedIn();
      allow read: if isAdmin();
    }

    match /supportMessages/{messageId} {
      allow create: if isSignedIn();
      allow read, write: if isAdmin();
    }

    match /users/{userId} {
      // Autorise toujours la lecture de son propre profil (pour détecter le lock en UI)
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin();
      allow create: if isSignedIn() && request.auth.uid == userId;
      
      // Un utilisateur peut s'auto-verrouiller (détection auto) mais seul l'admin peut déverrouiller
      allow update: if isSignedIn() && (
        isAdmin() || 
        (request.auth.uid == userId && resource.data.isLocked != true)
      );
      
      match /{allSubcollections=**} {
        allow read, write: if (request.auth.uid == userId || isAdmin()) && isNotLocked();
      }
    }
  }
}
