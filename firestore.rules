
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && (
        request.auth.uid == "vwyrAnNtQkSojYSEEK2qkRB5feh2" || 
        request.auth.uid == "GPgreBe1JzZYbEHQGn3xIdcQGQs1" ||
        request.auth.uid == "ve5V0MUPoccuOdBNGYsz6QYY89L2" ||
        (request.auth.token.email != null && (
          request.auth.token.email.lower() == "slim.besbes@yahoo.fr" ||
          request.auth.token.email.lower() == "contact@inovexio.com"
        ))
      );
    }

    // 1. SERVICES SYSTÈME (Priorité Haute)
    // Permettre la création de logs et d'emails pour le suivi
    match /userLogs/{logId} {
      allow create: if isSignedIn();
      allow read: if isAdmin();
    }

    match /mail/{mailId} {
      allow create: if isSignedIn();
      allow read: if isAdmin();
    }

    match /supportMessages/{messageId} {
      allow create: if isSignedIn();
      allow read, write: if isAdmin();
    }

    // 2. PROFILS UTILISATEURS
    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
      
      match /{allSubcollections=**} {
        allow read, write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      }
    }

    // 3. CONTENUS ET CONFIGURATION
    match /questions/{questionId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /coachingSessions/{sessionId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /coachingGroups/{groupId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /config/{configId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // 4. RÉSULTATS ET TENTATIVES
    match /coachingAttempts/{attemptId} {
      allow read: if isSignedIn() && (isAdmin() || (resource != null && resource.data.userId == request.auth.uid));
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && (isAdmin() || (resource != null && resource.data.userId == request.auth.uid));
      allow update: if isAdmin();
    }

    match /quickQuizAttempts/{attemptId} {
      allow read: if isSignedIn() && (isAdmin() || (resource != null && resource.data.userId == request.auth.uid));
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && (isAdmin() || (resource != null && resource.data.userId == request.auth.uid));
      allow update: if isAdmin();
    }

    // 5. RESSOURCES PÉDAGOGIQUES
    match /mindsets/{mindsetId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    match /concepts_approaches/{approachId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    match /concepts_domains/{domainId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // 6. CHATS IA
    match /chats/{chatId} {
      allow read, write: if isAdmin() || (isSignedIn() && request.auth.uid == chatId);
      match /messages/{msgId} {
        allow create: if isSignedIn() && (request.auth.uid == chatId || isAdmin());
        allow read: if isSignedIn() && (request.auth.uid == chatId || isAdmin());
      }
    }

    // 7. SÉCURITÉ GLOBALE POUR L'ADMINISTRATEUR
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
