
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && (
        request.auth.uid in [
          "vwyrAnNtQkSojYSEEK2qkRB5feh2", 
          "GPgreBe1JzZYbEHQGn3xIdcQGQs1", 
          "ve5V0MUPoccuOdBNGYsz6QYY89L2", 
          "Adknzym5N6cMeJnYbCRaAdBrA0r1"
        ] || 
        (request.auth.token.email != null && 
         request.auth.token.email.lower() in [
           "slim.besbes@yahoo.fr", 
           "contact@inovexio.com", 
           "jedgrira1@gmail.com"
         ])
      );
    }

    function isNotLocked() {
      let userPath = /databases/$(database)/documents/users/$(request.auth.uid);
      return !exists(userPath) || get(userPath).data.isLocked != true;
    }

    // Accès aux collections principales
    match /questions/{q} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /coachingSessions/{s} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /coachingGroups/{g} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /coachingAttempts/{a} { 
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn();
      allow delete: if isAdmin();
    }
    match /quickQuizAttempts/{q} { allow read, write: if isSignedIn(); }
    
    match /userLogs/{logId} {
      allow create: if isSignedIn();
      allow read: if isAdmin();
    }

    match /supportMessages/{messageId} {
      allow create: if isSignedIn();
      allow read, write: if isAdmin();
    }

    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && (
        isAdmin() || 
        (request.auth.uid == userId && isNotLocked())
      );
      
      match /{allSubcollections=**} {
        allow read, write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      }
    }
    
    match /mail/{mailId} {
      allow create: if isSignedIn();
      allow read: if isAdmin();
    }
  }
}
