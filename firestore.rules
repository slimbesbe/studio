
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isNotLocked() {
      // Un utilisateur verrouillé par la sécurité ne peut plus rien faire
      return !isSignedIn() || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isLocked != true;
    }
    
    function isAdmin() {
      return isSignedIn() && (
        request.auth.uid in [
          "vwyrAnNtQkSojYSEEK2qkRB5feh2", 
          "GPgreBe1JzZYbEHQGn3xIdcQGQs1", 
          "ve5V0MUPoccuOdBNGYsz6QYY89L2", 
          "Adknzym5N6cMeJnYbCRaAdBrA0r1"
        ] || 
        (request.auth.token.email != null && 
         request.auth.token.email.lower() in [
           "slim.besbes@yahoo.fr", 
           "contact@inovexio.com", 
           "jedgrira1@gmail.com"
         ])
      );
    }

    // Sécurité globale : Pas d'accès si le compte est verrouillé (sauf pour l'admin)
    match /{document=**} {
      allow read, write: if isAdmin() || (isSignedIn() && isNotLocked());
    }

    match /userLogs/{logId} {
      allow create: if isSignedIn();
      allow read: if isAdmin();
    }

    match /mail/{mailId} {
      allow create: if isSignedIn();
      allow read: if isAdmin();
    }

    match /supportMessages/{messageId} {
      allow create: if isSignedIn();
      allow read, write: if isAdmin();
    }

    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin();
      allow create: if isSignedIn() && request.auth.uid == userId;
      // Autorise l'update du champ isLocked lors du blocage automatique
      allow update: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      
      match /{allSubcollections=**} {
        allow read, write: if (request.auth.uid == userId || isAdmin()) && isNotLocked();
      }
    }
  }
}
