
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- FONCTIONS DE BASE ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function getUserData() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid)) 
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data 
        : {"role": "none"};
    }

    // --- LOGIQUE DES RÔLES ---
    function isSuperAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "slim.besbes@yahoo.fr" ||
        request.auth.uid == "vwyrAnNtQkSojYSEEK2qkRB5feh2" || 
        request.auth.uid == "GPgreBe1JzZYbEHQGn3xIdcQGQs1" ||
        getUserData().role == "super_admin"
      );
    }

    function isAdmin() { 
      return isSuperAdmin() || (isSignedIn() && (getUserData().role == "admin"));
    }

    function isCoach() {
      return isSignedIn() && getUserData().role == "coach";
    }

    function isPartner() {
      return isSignedIn() && getUserData().role == "partner";
    }

    // --- RÈGLES PAR COLLECTION ---

    // Collection technique pour les accès admin
    match /roles_admin/{userId} {
      allow read, write: if isSuperAdmin();
    }

    match /users/{userId} {
      allow get: if isSignedIn() && (
        request.auth.uid == userId || 
        isAdmin() || 
        (isCoach() && resource.data.groupId in getCoachGroupIds()) ||
        (isPartner() && resource.data.partnerId == request.auth.uid)
      );
      
      allow list: if isSignedIn() && (
        isAdmin() || 
        isCoach() || 
        isPartner()
      );

      // Autoriser la création si Admin/Partner ou si c'est le Super Admin qui s'auto-enregistre
      allow create: if isAdmin() || isPartner() || (request.auth.uid == userId && request.auth.token.email == "slim.besbes@yahoo.fr");
      
      allow update: if isSignedIn() && (
        isAdmin() || 
        (request.auth.uid == userId && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'status', 'groupId', 'partnerId', 'validUntil'])) ||
        (isPartner() && resource.data.partnerId == request.auth.uid)
      );
      
      allow delete: if isAdmin();
    }

    match /coachingGroups/{groupId} {
      allow read: if isSignedIn() && (
        isAdmin() || 
        (isCoach() && resource.data.coachId == request.auth.uid) ||
        (isPartner() && resource.data.partnerId == request.auth.uid) ||
        (getUserData().groupId == groupId)
      );
      allow write: if isAdmin() || (isPartner() && request.resource.data.partnerId == request.auth.uid);
    }

    match /questions/{questionId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    match /coachingSessions/{sessionId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /coachingAttempts/{attemptId} {
      allow read: if isSignedIn() && (
        isAdmin() || 
        resource.data.userId == request.auth.uid ||
        (isCoach() && resource.data.groupId in getCoachGroupIds()) ||
        (isPartner() && exists(/databases/$(database)/documents/users/$(resource.data.userId)) && get(/databases/$(database)/documents/users/$(resource.data.userId)).data.partnerId == request.auth.uid)
      );
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // --- HELPERS ---
    function getCoachGroupIds() {
      return []; 
    }
  }
}
