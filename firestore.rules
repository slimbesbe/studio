
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // --- FONCTIONS DE SÉCURITÉ ---
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isSuperAdmin() {
      return isSignedIn() && (
        request.auth.uid == "vwyrAnNtQkSojYSEEK2qkRB5feh2" || 
        request.auth.uid == "GPgreBe1JzZYbEHQGn3xIdcQGQs1" ||
        request.auth.token.email == "slim.besbes@yahoo.fr"
      );
    }

    function isAdmin() { 
      return isSuperAdmin() || (isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)));
    }

    // --- RÈGLES GLOBALES ---
    match /{document=**} {
      allow read, write: if isAdmin();
    }

    // --- RÈGLES UTILISATEURS ---
    match /roles_admin/{uid} {
      allow read: if isSignedIn() && request.auth.uid == uid;
    }
    
    match /users/{userId} {
      allow get: if isSignedIn() && request.auth.uid == userId;
      // Empêcher l'auto-promotion ou le changement de statut par l'utilisateur lui-même
      allow update: if isSignedIn() && request.auth.uid == userId 
                    && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'status', 'accessType', 'groupId', 'allowedExams']);
      
      match /{allSubcollections=**} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
    }

    match /questions/{questionId} {
      allow read, list: if isSignedIn();
    }
    
    match /coachingSessions/{sessionId} {
      allow read, list: if isSignedIn();
    }

    match /coachingAttempts/{attemptId} {
      // Un utilisateur peut lire ses propres tentatives (individuellement ou en liste)
      // Firestore applique automatiquement cette règle à chaque document d'une requête de liste
      allow read: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
      
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /coachingGroups/{groupId} {
      allow get, list: if isSignedIn();
    }

    match /exams/{examId} {
      allow read: if isSignedIn();
      match /{allSubcollections=**} { allow read: if isSignedIn(); }
    }
    
    match /users/{userId}/exam_results/{resultId} {
      allow read, write: if isSignedIn() && (isAdmin() || request.auth.uid == userId);
    }
    
    match /{path=**}/exam_results/{resultId} {
      allow read: if isSignedIn() && (isAdmin() || (resource != null && request.auth.uid == resource.data.userId));
    }
  }
}
