
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- FONCTIONS DE BASE ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // --- LOGIQUE DES RÔLES ---
    function isSuperAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "slim.besbes@yahoo.fr" ||
        request.auth.uid == "vwyrAnNtQkSojYSEEK2qkRB5feh2" || 
        request.auth.uid == "GPgreBe1JzZYbEHQGn3xIdcQGQs1" ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().role == "super_admin")
      );
    }

    function isAdmin() { 
      return isSuperAdmin() || (isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().role == "admin");
    }

    function isCoach() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().role == "coach";
    }

    function isPartner() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().role == "partner";
    }

    // --- RÈGLES PAR COLLECTION ---

    match /roles_admin/{userId} {
      allow read, write: if isSuperAdmin();
    }

    match /users/{userId} {
      allow read: if isSignedIn() && (
        request.auth.uid == userId || 
        isAdmin() || 
        isCoach() || 
        isPartner()
      );
      
      allow create: if isAdmin() || isPartner() || (request.auth.uid == userId && request.auth.token.email == "slim.besbes@yahoo.fr");
      
      allow update: if isSignedIn() && (
        isAdmin() || 
        (request.auth.uid == userId) ||
        (isPartner() && resource.data.partnerId == request.auth.uid)
      );
      
      allow delete: if isAdmin();
    }

    match /coachingGroups/{groupId} {
      allow read: if isSignedIn() && (
        isAdmin() || 
        (isCoach() && resource.data.coachId == request.auth.uid) ||
        (isPartner() && resource.data.partnerId == request.auth.uid) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().groupId == groupId)
      );
      allow write: if isAdmin() || (isPartner() && request.resource.data.partnerId == request.auth.uid);
    }

    match /questions/{questionId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    match /coachingSessions/{sessionId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /coachingAttempts/{attemptId} {
      allow read: if isSignedIn() && (
        isAdmin() || 
        resource.data.userId == request.auth.uid ||
        isCoach() ||
        isPartner()
      );
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }
  }
}
