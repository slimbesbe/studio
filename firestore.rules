
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- FONCTIONS DE BASE ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    // ACCÈS PRIORITAIRE ABSOLU POUR L'ADMINISTRATEUR
    function isSuperAdmin() {
      return (
        isSignedIn() && (
          request.auth.token.email.lower() == "slim.besbes@yahoo.fr" ||
          request.auth.uid == "vwyrAnNtQkSojYSEEK2qkRB5feh2" || 
          request.auth.uid == "GPgreBe1JzZYbEHQGn3xIdcQGQs1"
        )
      );
    }

    function isAdmin() { 
      return isSuperAdmin() || (isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin");
    }

    // L'admin peut tout faire partout
    match /{document=**} {
      allow read, write: if isSuperAdmin();
    }

    match /users/{userId} {
      // Autoriser la lecture par email pour la vérification à la connexion (désynchronisation)
      // On autorise la liste si le filtre est sur l'email et limité à 1
      allow list: if (request.query.limit == 1);
      allow get: if isSignedIn() || (request.auth.uid == userId);
      
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }

    match /roles_admin/{userId} {
      allow read, write: if isSignedIn();
    }

    match /coachingGroups/{groupId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /questions/{questionId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    match /coachingSessions/{sessionId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /coachingAttempts/{attemptId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }
  }
}
