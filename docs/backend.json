
{
  "entities": {
    "User": {
      "title": "User",
      "type": "object",
      "description": "Utilisateur Simu-lux avec statistiques de performance et sécurité anti-partage.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "role": { "type": "string", "enum": ["super_admin", "admin", "coach", "partner", "user", "demo"] },
        "status": { "type": "string", "enum": ["active", "disabled", "expired", "suspended", "pending"] },
        "isLocked": { "type": "boolean", "description": "Verrouillage de sécurité anti-partage" },
        "lockReason": { "type": "string", "enum": ["multi-device", "admin-lock"] },
        "activeSession": {
          "type": "object",
          "properties": {
            "deviceId": { "type": "string" },
            "lastSeen": { "type": "string", "format": "date-time" }
          }
        },
        "accessType": { "type": "string", "enum": ["simulation", "coaching", "coaching_simulation", "simulation_only", "coaching_only", "simulation_and_coaching"] },
        "groupId": { "type": "string" },
        "partnerId": { "type": "string" },
        "assignedCoachId": { "type": "string" },
        "validUntil": { "type": "string", "format": "date-time" },
        "targetExamDate": { "type": "string", "format": "date-time" },
        "simulationsCount": { "type": "number" },
        "averageScore": { "type": "number" },
        "totalTimeSpent": { "type": "number" },
        "allowedExams": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "SupportMessage": {
      "title": "SupportMessage",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "userName": { "type": "string" },
        "subject": { "type": "string" },
        "message": { "type": "string" },
        "status": { "type": "string", "enum": ["unread", "read", "replied"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "ChatMessage": {
      "title": "ChatMessage",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "assistant"] },
        "content": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "CoachingSession": {
      "title": "CoachingSession",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "index": { "type": "number" },
        "title": { "type": "string" },
        "type": { "type": "string", "enum": ["MEET", "QUIZ"] },
        "meetLink": { "type": "string" },
        "questionStart": { "type": "number" },
        "questionEnd": { "type": "number" },
        "isPublished": { "type": "boolean" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/questions/{questionId}",
        "definition": { "schema": { "$ref": "#/backend/entities/Question" }, "description": "Banque centrale" }
      },
      {
        "path": "/supportMessages/{messageId}",
        "definition": { "schema": { "$ref": "#/backend/entities/SupportMessage" }, "description": "Messages utilisateurs pour l'admin" }
      },
      {
        "path": "/chats/{chatId}/messages/{messageId}",
        "definition": { "schema": { "$ref": "#/backend/entities/ChatMessage" }, "description": "Historique des chats IA" }
      },
      {
        "path": "/users/{userId}",
        "definition": { "schema": { "$ref": "#/backend/entities/User" }, "description": "Profils participants avec champs de sécurité" }
      },
      {
        "path": "/mail/{mailId}",
        "definition": { "schema": { "type": "object" }, "description": "Emails sortants (Extension Trigger Email)" }
      }
    ]
  }
}
