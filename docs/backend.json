
{
  "entities": {
    "User": {
      "title": "User",
      "type": "object",
      "description": "Utilisateur Simu-lux avec statistiques de performance et accès coaching.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "role": { "type": "string", "enum": ["super_admin", "admin", "coach", "partner", "user"] },
        "status": { "type": "string", "enum": ["active", "disabled", "expired", "suspended", "pending"] },
        "accessType": { "type": "string", "enum": ["simulation", "coaching", "coaching_simulation", "simulation_only", "coaching_only", "simulation_and_coaching"] },
        "groupId": { "type": "string" },
        "partnerId": { "type": "string", "description": "ID du partenaire B2B si applicable" },
        "assignedCoachId": { "type": "string" },
        "validUntil": { "type": "string", "format": "date-time" },
        "targetExamDate": { "type": "string", "format": "date-time", "description": "Date cible de l'examen PMP" },
        "targetExamDateUpdatedAt": { "type": "string", "format": "date-time" },
        "simulationsCount": { "type": "number" },
        "averageScore": { "type": "number" },
        "totalTimeSpent": { "type": "number" },
        "allowedExams": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "SupportMessage": {
      "title": "SupportMessage",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "userName": { "type": "string" },
        "subject": { "type": "string" },
        "message": { "type": "string" },
        "status": { "type": "string", "enum": ["unread", "read", "replied"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "ChatMessage": {
      "title": "ChatMessage",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "assistant"] },
        "content": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "CoachingSession": {
      "title": "CoachingSession",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "index": { "type": "number" },
        "title": { "type": "string" },
        "type": { "type": "string", "enum": ["MEET", "QUIZ"] },
        "meetLink": { "type": "string" },
        "questionStart": { "type": "number" },
        "questionEnd": { "type": "number" },
        "isPublished": { "type": "boolean" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "CoachingGroup": {
      "title": "CoachingGroup",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "coachId": { "type": "string" },
        "partnerId": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "archived", "draft"] },
        "maxUsers": { "type": "number" },
        "startDate": { "type": "string", "format": "date-time" },
        "endDate": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "CoachingAttempt": {
      "title": "CoachingAttempt",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "groupId": { "type": "string" },
        "sessionId": { "type": "string" },
        "scorePercent": { "type": "number" },
        "correctCount": { "type": "number" },
        "totalQuestions": { "type": "number" },
        "durationSec": { "type": "number" },
        "submittedAt": { "type": "string", "format": "date-time" }
      }
    },
    "QuickQuizAttempt": {
      "title": "QuickQuizAttempt",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "axisId": { "type": "string" },
        "category": { "type": "string", "enum": ["approach", "domain"] },
        "score": { "type": "number" },
        "correctCount": { "type": "number" },
        "totalQuestions": { "type": "number" },
        "submittedAt": { "type": "string", "format": "date-time" }
      }
    },
    "Question": {
      "title": "Question",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "index": { "type": "number" },
        "text": { "type": "string" },
        "imageUrl": { "type": "string" },
        "choices": { "type": "array", "items": { "type": "string" } },
        "correctChoice": { "type": "string" },
        "correctChoiceIds": { "type": "array", "items": { "type": "string" } },
        "explanation": { "type": "string" },
        "tags": {
          "type": "object",
          "properties": {
            "domain": { "type": "string" },
            "approach": { "type": "string" },
            "difficulty": { "type": "string" }
          }
        }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/questions/{questionId}",
        "definition": { "schema": { "$ref": "#/backend/entities/Question" }, "description": "Banque centrale" }
      },
      {
        "path": "/supportMessages/{messageId}",
        "definition": { "schema": { "$ref": "#/backend/entities/SupportMessage" }, "description": "Messages utilisateurs pour l'admin" }
      },
      {
        "path": "/chats/{chatId}/messages/{messageId}",
        "definition": { "schema": { "$ref": "#/backend/entities/ChatMessage" }, "description": "Historique des chats IA" }
      },
      {
        "path": "/coachingSessions/{sessionId}",
        "definition": { "schema": { "$ref": "#/backend/entities/CoachingSession" }, "description": "Configuration S1..S6" }
      },
      {
        "path": "/coachingGroups/{groupId}",
        "definition": { "schema": { "$ref": "#/backend/entities/CoachingGroup" }, "description": "Groupes de participants" }
      },
      {
        "path": "/coachingAttempts/{attemptId}",
        "definition": { "schema": { "$ref": "#/backend/entities/CoachingAttempt" }, "description": "Scores coaching et simulations" }
      },
      {
        "path": "/quickQuizAttempts/{attemptId}",
        "definition": { "schema": { "$ref": "#/backend/entities/QuickQuizAttempt" }, "description": "Scores des quiz rapides par axe" }
      },
      {
        "path": "/users/{userId}",
        "definition": { "schema": { "$ref": "#/backend/entities/User" }, "description": "Profils participants" }
      }
    ]
  }
}
